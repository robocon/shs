	"SHS Create HTML": {
		"prefix": "html:shs",
		"body": [
			"<!DOCTYPE html>",
			"<html lang=\"en\">",
			"<head>",
			"	<meta charset=\"UTF-8\">",
			"	<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">",
			"	<title>${1:TITLE}</title>",
			"	<link rel=\"icon\" href=\"images/favicon-16x16.png\" sizes=\"16x16\" type=\"image/png\">",
			"	<link href=\"bootstrap/css/bootstrap.min.css\" rel=\"stylesheet\">",
			"	<link href=\"bootstrap/bootstrap-icons-1.11.3/font/bootstrap-icons.min.css\" rel=\"stylesheet\">",
			"	<script src=\"bootstrap/js/bootstrap.bundle.min.js\"></script>",
			"	<script src=\"js/sweetalert2.all.min.js\"></script>",
			"</head>",
			"<body>",
			"	$2",
			"</body>",
			"</html>",
		],
		"description": "ทดสอบสร้าง html:5"
	},
	"Create tinymce": {
		"prefix": "tinymce",
		"body": [
			"<script src=\"js/tinymce/tinymce.min.js\" referrerpolicy=\"origin\"></script>",
			"<script>",
			"	tinymce.init({",
			"		selector: 'textarea#detail',",
			"		toolbar: false, // ปิดใช้งาน toolbar",
			"		menubar: false, // ปิดใช้งาน menubar",
			"		forced_root_block : '' // ไม่ต้องใช้ tag p เมื่อเริ่มต้นใช้งาน tinymce",
			"	});",
			"</script>",
		],
		"description": "เรียกใช้ tinymce"
	},
	"Create div container": {
		"prefix": "container",
		"body": [
			"	<div class=\"container\">$1</div>",
		],
		"description": "สร้าง container"
	},
	"Create table bootstrap": {
		"prefix": "tb:bootstrap",
		"body": [
			"<table class=\"table\">",
			"	<tr>",
			"		<th>$1</th>",
			"	</tr>",
			"	<tr>",
			"		<td>$2</td>",
			"	</tr>",
			"</table>"
		],
		"description": "สร้าง table bootstrap แบบง่ายๆ"
	},
	"Create nav bootstrap": {
		"prefix": "nav",
		"body": [
			"<style>",
			"	#$1{",
			"		background-color: #13795b;",
			"		color:#ffffff;",
			"	}",
			"</style>",
			"<nav class=\"navbar navbar-expand-lg\" id=\"$2\" data-bs-theme=\"dark\">",
			"	<div class=\"container-fluid\">",
			"	<a class=\"navbar-brand\" href=\"../nindex.htm\">Home</a>",
			"	<button class=\"navbar-toggler\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#navbarSupportedContent\" aria-controls=\"navbarSupportedContent\" aria-expanded=\"false\" aria-label=\"Toggle navigation\">",
			"		<span class=\"navbar-toggler-icon\"></span>",
			"	</button>",
			"	<div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\">",
			"		<ul class=\"navbar-nav me-auto mb-2 mb-lg-0\">",
			"		<li class=\"nav-item\">",
			"			<a class=\"nav-link active\" aria-current=\"page\" href=\"#\">รายชื่อ</a>",
			"		</li>",
			"		</ul>",
			"	</div>",
			"	</div>",
			"</nav>",
		],
		"description": "สร้าง nav bootstrap แบบง่ายๆ"
	},
