	"include bootstrap.php": {
		"prefix": "reboot",
		"body": [
			"require_once 'bootstrap.php';",
			"\\$dbi = new mysqli(HOST,USER,PASS,DB);",
			"\\$dbi->query(\"SET NAMES UTF8\");"
		],
		"description": "include bootstrap.php"
	},
	"create dump()": {
		"prefix": "fdump",
		"body": [
			"function dump(\\$t){",
			"	echo \"<pre>\";",
			"	var_dump(\\$t);",
			"	echo \"</pre>\";",
			"}",
		],
		"description": "create basic var_dump()"
	}
